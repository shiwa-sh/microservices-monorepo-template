# Local inner-loop environment for `catalog` (ADR-0003 minimal profile).
# Copy to .env, then `mise run run` / your IDE's debugger picks it up.
#
# Prereqs:
#   mise run dev:up -- --minimal
#
# DATABASE_URL points at the port-forwarded CNPG cluster on localhost:5432.
# Grab the live password once with:
#   kubectl -n platform get secret postgres-app -o jsonpath='{.data.password}' | base64 -d
DATABASE_URL=postgres://app:CHANGE_ME@localhost:5432/app?sslmode=disable

# OTel-LGTM bundle exposed by dev-portforward.sh.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
