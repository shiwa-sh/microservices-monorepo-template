# Local inner-loop environment for `catalog` (ADR-0003).
# Copy to .env, then `mise run run` / your IDE's debugger picks it up.
#
# Prereqs (brings up the local deps and port-forwards Postgres to localhost:5432):
#   mise run cluster:lite
#   mise run dev -m platform
#
# DATABASE_URL points at the port-forwarded local Postgres (see infra/local/deps.yaml).
DATABASE_URL=postgres://dev:dev@localhost:5432/catalog?sslmode=disable

# Uncomment when running an OTel collector locally (none ships in the dev deps).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
