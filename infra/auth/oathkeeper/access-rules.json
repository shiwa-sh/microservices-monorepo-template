[
  {
    "id": "api-services",
    "match": { "url": "<{http,https}>://<**>/api/<{catalog,orders,orgs,payment}>/<**>", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    "authenticators": [{ "handler": "cookie_session" }, { "handler": "jwt" }, { "handler": "anonymous" }],
    "authorizer": { "handler": "allow" },
    "mutators": [{ "handler": "header" }],
    "errors": [{ "handler": "json" }]
  },
  {
    "id": "ops-console",
    "match": { "url": "<{http,https}>://console.ops.<**>/<**>", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    "authenticators": [{ "handler": "cookie_session" }],
    "authorizer": { "handler": "remote_json", "config": { "remote": "http://authz-server.platform.svc.cluster.local/internal/authorize", "payload": "{\"subject\":\"{{ print .Subject }}\",\"tool\":\"console\",\"aal\":\"{{ print .Extra.authenticator_assurance_level }}\"}" } },
    "mutators": [{ "handler": "header", "config": { "headers": { "X-User-Id": "{{ print .Subject }}", "X-User-Email": "{{ print .Extra.identity.traits.email }}" } } }],
    "errors": [{ "handler": "redirect" }]
  },
  {
    "id": "ops-hubble",
    "match": { "url": "<{http,https}>://hubble.ops.<**>/<**>", "methods": ["GET", "POST"] },
    "authenticators": [{ "handler": "cookie_session" }],
    "authorizer": { "handler": "remote_json", "config": { "remote": "http://authz-server.platform.svc.cluster.local/internal/authorize", "payload": "{\"subject\":\"{{ print .Subject }}\",\"tool\":\"hubble\",\"aal\":\"{{ print .Extra.authenticator_assurance_level }}\"}" } },
    "mutators": [{ "handler": "noop" }],
    "errors": [{ "handler": "redirect" }]
  },
  {
    "id": "ops-grafana",
    "match": { "url": "<{http,https}>://grafana.ops.<**>/<**>", "methods": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
