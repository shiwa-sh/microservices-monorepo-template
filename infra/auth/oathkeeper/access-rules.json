    "authorizer": { "handler": "remote_json", "config": { "remote": "http://authz-server.platform.svc.cluster.local/internal/authorize", "payload": "{\"subject\":\"{{ print .Subject }}\",\"tool\":\"grafana\",\"aal\":\"{{ print .Extra.authenticator_assurance_level }}\"}" } },
    "mutators": [{ "handler": "noop" }],
    "errors": [{ "handler": "redirect" }]
  },
  {
