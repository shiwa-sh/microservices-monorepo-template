{
  "$id": "https://example.com/identity-schemas/user.v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "properties": {
    "traits": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "title": "E-Mail",
          "ory.sh/kratos": {
            "credentials": { "password": { "identifier": true } },
            "verification": { "via": "email" },
            "recovery":     { "via": "email" }
          }
        },
        "name": { "type": "string", "title": "Name" }
      },
      "required": ["email"],
      "additionalProperties": false
    }
  }
}
